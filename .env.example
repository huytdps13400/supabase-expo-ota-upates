# Supabase OTA Updates Configuration
# Copy this file to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OTA Configuration
EXPO_PUBLIC_OTA_URL=https://your-project.supabase.co/functions/v1/ota-manifest
EXPO_PUBLIC_ENV=DEV

# App Version (used to derive runtimeVersion)
VERSION_NUMBER=1.0.0
IOS_BUILD_NUMBER=1
ANDROID_BUILD_NUMBER=1

# Optional: Google Chat notifications
GOOGLE_CHAT_WEBHOOK=
